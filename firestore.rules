rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isExistingDirectParticipant(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/directChats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/directChats/$(chatId)).data.participants;
    }

    function isDirectParticipantData(data) {
      return signedIn()
        && data.participants is list
        && request.auth.uid in data.participants;
    }

    function isDirectMessageParticipant(data) {
      return signedIn() && (
        (data.directId is string && isExistingDirectParticipant(data.directId))
        || (data.participants is list && request.auth.uid in data.participants)
        || data.senderId == request.auth.uid
        || data.receiverId == request.auth.uid
        || data.toUserId == request.auth.uid
      );
    }

    function isRequestParticipant(data) {
      return signedIn()
        && (data.fromUserId == request.auth.uid || data.toUserId == request.auth.uid);
    }

    function isPersonalOwner(data) {
      return signedIn() && data.userId == request.auth.uid;
    }

    function isCallParticipant(data) {
      return signedIn()
        && (
          data.fromUserId == request.auth.uid
          || data.toUserId == request.auth.uid
          || (data.participantIds is list && request.auth.uid in data.participantIds)
        );
    }

    function validMessageUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'deletedForEveryone',
        'deletedForEveryoneBy',
        'deletedForEveryoneAt'
      ]) || (
        resource.data.senderId == request.auth.uid
        && request.resource.data.deletedForEveryone == true
        && request.resource.data.deletedForEveryoneBy == request.auth.uid
      );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow update: if isOwner(userId)
        && (!('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid);
      allow delete: if false;
    }

    match /directChats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow update, delete: if isExistingDirectParticipant(chatId);
      allow create: if isDirectParticipantData(request.resource.data);
    }

    match /messages/{messageId} {
      allow read: if signedIn() && (
        isDirectMessageParticipant(resource.data)
        || (resource.data.groupId is string)
      );
      allow create: if signedIn() && request.resource.data.senderId == request.auth.uid && (
        (request.resource.data.directId is string && isExistingDirectParticipant(request.resource.data.directId))
        || (request.resource.data.groupId is string)
      );
      allow update: if signedIn() && validMessageUpdate() && (
        isDirectMessageParticipant(resource.data)
        || (resource.data.groupId is string)
      );
      allow delete: if signedIn() && resource.data.senderId == request.auth.uid;
    }

    match /chatRequests/{requestId} {
      allow read: if isRequestParticipant(resource.data);
      allow create: if isRequestParticipant(request.resource.data)
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isRequestParticipant(resource.data)
        && (
          (
            resource.data.status == 'pending'
            && resource.data.toUserId == request.auth.uid
            && request.resource.data.status in ['accepted', 'declined']
            && request.resource.data.fromUserId == resource.data.fromUserId
            && request.resource.data.toUserId == resource.data.toUserId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'respondedAt'
            ])
          )
          || (
            resource.data.status == 'pending'
            && resource.data.fromUserId == request.auth.uid
            && request.resource.data.status == 'cancelled'
            && request.resource.data.fromUserId == resource.data.fromUserId
            && request.resource.data.toUserId == resource.data.toUserId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'respondedAt'
            ])
          )
          || (
            resource.data.status in ['declined', 'cancelled']
            && request.resource.data.status == 'pending'
            && request.resource.data.fromUserId == request.auth.uid
            && request.resource.data.toUserId != request.auth.uid
            && request.resource.data.fromUserId in [
              resource.data.fromUserId,
              resource.data.toUserId
            ]
            && request.resource.data.toUserId in [
              resource.data.fromUserId,
              resource.data.toUserId
            ]
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'fromUserId',
              'fromUserName',
              'fromUserEmail',
              'toUserId',
              'toUserName',
              'toUserEmail',
              'status',
              'createdAt',
              'respondedAt'
            ])
          )
        );
      allow delete: if false;
    }

    match /inAppNotifications/{notificationId} {
      allow read: if signedIn() && resource.data.toUserId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.toUserId == request.auth.uid
        && request.resource.data.toUserId == resource.data.toUserId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      // Group admin data currently lives in groupMembers, so keep group updates
      // compatible with the app's existing admin/member workflows.
      allow update, delete: if signedIn();
    }

    match /groupMembers/{memberId} {
      allow read: if signedIn();
      // Existing flows let admins invite, remove, and promote other members.
      // The app does those checks client-side until group admin rules are migrated.
      allow create, update, delete: if signedIn();
    }

    match /groupInvites/{inviteId} {
      allow read, update, delete: if isRequestParticipant(resource.data);
      allow create: if isRequestParticipant(request.resource.data)
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == 'pending';
    }

    match /blockedUsers/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /favoriteChats/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /archivedChats/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /lockedChats/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /chatLockSettings/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /chatTranslationSettings/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /deletedChats/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /mutedChats/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /quickReplies/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /pinnedMessages/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /starredMessages/{docId} {
      allow read, update, delete: if isPersonalOwner(resource.data);
      allow create: if isPersonalOwner(request.resource.data);
    }

    match /messageReactions/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && (
        request.resource.data.userId == request.auth.uid
        || resource.data.userId == request.auth.uid
      );
    }

    match /typingIndicators/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && (
        request.resource.data.userId == request.auth.uid
        || resource.data.userId == request.auth.uid
      );
    }

    match /statuses/{statusId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /calls/{callId} {
      allow read, update, delete: if isCallParticipant(resource.data);
      allow create: if isCallParticipant(request.resource.data)
        && request.resource.data.fromUserId == request.auth.uid;

      match /{sub=**} {
        allow read, write: if signedIn()
          && exists(/databases/$(database)/documents/calls/$(callId))
          && isCallParticipant(get(/databases/$(database)/documents/calls/$(callId)).data);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
